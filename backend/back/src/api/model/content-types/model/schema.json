{
  "kind": "collectionType",
  "collectionName": "models",
  "info": {
    "singularName": "model",
    "pluralName": "models",
    "displayName": "Model",
    "description": "An Ollama model available on a Machine"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "displayName": {
      "type": "string"
    },
    "paramSize": {
      "type": "string"
    },
    "machine": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::machine.machine",
      "inversedBy": "models"
    },
    "conversations": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::conversation.conversation",
      "mappedBy": "models"
    }
  }
}
