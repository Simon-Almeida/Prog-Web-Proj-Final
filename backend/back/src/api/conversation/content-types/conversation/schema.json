{
  "kind": "collectionType",
  "collectionName": "conversations",
  "info": {
    "singularName": "conversation",
    "pluralName": "conversations",
    "displayName": "Conversation",
    "description": "A chat session between a user and one or more models"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "tab": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::tab.tab",
      "inversedBy": "conversations"
    },
    "models": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::model.model",
      "inversedBy": "conversations"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "conversations"
    }
  }
}
